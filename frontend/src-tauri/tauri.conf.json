{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Shigawire",
  "version": "0.1.1",
  "identifier": "dev.shigawire.desktop",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev:tauri",
    "beforeBuildCommand": "npm run sidecar:prepare && npm run build:tauri"
  },
  "app": {
    "windows": [
      {
        "title": "Shigawire",
        "width": 1280,
        "height": 880,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:* ws://127.0.0.1:* ws://localhost:* ipc: tauri:; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' https: data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "externalBin": [
      "binaries/shigawire-server"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-",
      "dmg": {
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "appPosition": {
          "x": 180,
          "y": 180
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 180
        }
      }
    },
    "windows": {
      "nsis": {
        "installerIcon": "./icons/icon.ico",
        "headerImage": "./images/nsis_header.bmp",
        "sidebarImage": "./images/nsis_sidebar.bmp",
        "installerHooks": "./installer-hooks.nsh"
      }
    }
  }
}
